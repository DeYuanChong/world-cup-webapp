# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worldcup

# Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Google OAuth client (Google Cloud Console).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Comma-separated list of Google account emails that get admin access
ADMIN_EMAILS=

# --- Dev only ---
# Override "now" for testing prediction locks (ignored in production)
# FAKE_NOW=2026-07-09T18:00:00Z
# Score sync poll interval in ms (default 300000 = 5 min)
# SYNC_INTERVAL_MS=300000
